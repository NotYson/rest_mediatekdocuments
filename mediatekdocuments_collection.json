        {
          "name": "GET tous les livres",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.test('Structure JSON valide', () => {",
            "  pm.expect(j).to.have.property('code');",
            "  pm.expect(j).to.have.property('message');",
            "  pm.expect(j).to.have.property('result');",
            "});",
            "pm.test('code = 200', () => pm.expect(j.code).to.eql(200));",
            "pm.test('result est un tableau non vide', () => {",
            "  pm.expect(j.result).to.be.an('array').and.not.empty;",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/livre", "host": ["{{base_url}}"], "path": ["livre"] }
          }
        },

        {
